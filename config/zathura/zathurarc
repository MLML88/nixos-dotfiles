# Recolor settings
set recolor true
set recolor-darkcolor "#c0caf5"
set recolor-lightcolor "#1a1b26"
set recolor-keephue false

# Adjust these for better contrast if needed
set recolor-reverse-video false

# Background and foreground
set default-bg rgba(26,27,38,0.9)
set default-fg "#c0caf5"

# Completion menu
set completion-bg "#1a1b26"
set completion-fg "#c0caf5"
set completion-group-bg "#1a1b26"
set completion-group-fg "#7aa2f7"
set completion-highlight-bg "#3b4261"
set completion-highlight-fg "#c0caf5"

# Statusbar
set statusbar-bg "#1a1b26"
set statusbar-fg "#c0caf5"

# Inputbar
set inputbar-bg "#1a1b26"
set inputbar-fg "#c0caf5"

# Notifications
set notification-bg "#1a1b26"
set notification-fg "#c0caf5"
set notification-error-bg "#f7768e"
set notification-error-fg "#1a1b26"
set notification-warning-bg "#e0af68"
set notification-warning-fg "#1a1b26"

# Index mode
set index-bg "#1a1b26"
set index-fg "#c0caf5"
set index-active-bg "#3b4261"
set index-active-fg "#c0caf5"

# Highlight color
set highlight-color "#e0af68"
set highlight-active-color "#9ece6a"

# Adjust opacity (requires compositor like picom)
set window-title-home-tilde true
set adjust-open "best-fit"
set pages-per-row 1

# Clipboard
set selection-clipboard clipboard
